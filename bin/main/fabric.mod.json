{
  "schemaVersion": 1,
  "id": "disc_jockey",
  "version": "${version}",
  "name": "Disc Jockey: Next",
  "description": "Play note block songs in Minecraft",
  "authors": [
    "SemmieDev",
    "EnderKill98",
    "Mimosa-pudica"
  ],
  "contact": {
    "repo": "https://github.com/xin-build/Disc-Jockey-Next"
  },
  "license": "MIT",
  "icon": "assets/disc_jockey/icon.png",
